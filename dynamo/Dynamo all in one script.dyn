    {
      "ConcreteType": "CoreNodeModels.Watch, CoreNodeModels",
      "WatchWidth": 200.0,
      "WatchHeight": 200.0,
      "Id": "e22ec214949f4e579cf7d90ec7a27cc7",
      "NodeType": "ExtensionNode",
      "Inputs": [
        {
          "Id": "392c53d102d84989bf47ce223e05f987",
          "Name": "",
          "Description": "Node to show output from",
          "UsingDefaultValue": false,
