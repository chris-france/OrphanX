    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference(\"RevitAPI\")\r\nclr.AddReference(\"RevitServices\")\r\n\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\nfrom System.Collections.Generic import List\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\ndata = IN[0]\r\n\r\nVIEW_NAME = \"Colored 3D View\"\r\n\r\n# =====================================================\r\n# SAFE ElementId\r\n# =====================================================\r\ndef to_eid(id_str):\r\n    try:\r\n        return ElementId(int(id_str))\r\n    except:\r\n        return None\r\n\r\n# =====================================================\r\n# CREATE VIEW (ALWAYS NEW)\r\n# =====================================================\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nvft_collector = FilteredElementCollector(doc).OfClass(ViewFamilyType).ToElements()\r\n\r\nview = None\r\nfor vft in vft_collector:\r\n    if vft.ViewFamily == ViewFamily.ThreeDimensional:\r\n        view = View3D.CreateIsometric(doc, vft.Id)\r\n        view.Name = VIEW_NAME\r\n        break\r\n\r\n# 🔥 ta bort template\r\ntry:\r\n    view.ViewTemplateId = ElementId.InvalidElementId\r\nexcept:\r\n    pass\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\n# =====================================================\r\n# GET SOLID FILL\r\n# =====================================================\r\nsolid_fill_id = None\r\nfills = FilteredElementCollector(doc).OfClass(FillPatternElement).ToElements()\r\n\r\nfor f in fills:\r\n    try:\r\n        if f.GetFillPattern().IsSolidFill:\r\n            solid_fill_id = f.Id\r\n            break\r\n    except:\r\n        pass\r\n\r\n# =====================================================\r\n# COLOR + COLLECT IDS\r\n# =====================================================\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\nproblem_ids = []\r\ncount = 0\r\n\r\ndef process(ids, color):\r\n    global count\r\n\r\n    for i in ids:\r\n        eid = to_eid(i)\r\n        if not eid:\r\n            continue\r\n\r\n        e = doc.GetElement(eid)\r\n        if not e:\r\n            continue\r\n\r\n        problem_ids.append(e.Id)\r\n\r\n        try:\r\n            ogs = OverrideGraphicSettings()\r\n\r\n            ogs.SetProjectionLineColor(color)\r\n            ogs.SetCutLineColor(color)\r\n\r\n            if solid_fill_id:\r\n                ogs.SetSurfaceForegroundPatternId(solid_fill_id)\r\n                ogs.SetSurfaceForegroundPatternColor(color)\r\n\r\n            view.SetElementOverrides(e.Id, ogs)\r\n            count += 1\r\n\r\n        except:\r\n            pass\r\n\r\n# 🔴 ORPHANS\r\nprocess(data[\"orphans\"], Color(255, 0, 0))\r\n\r\n# 🟡 DEAD ENDS\r\nprocess(data[\"dead_ends\"], Color(255, 255, 0))\r\n\r\n# 🔵 ISOLATED\r\nprocess(data[\"isolated\"], Color(0, 255, 255))\r\n\r\n# =====================================================\r\n# 🔥 ISOLATE ELEMENTS (DETTA FIXAR ALLT)\r\n# =====================================================\r\nif problem_ids:\r\n    try:\r\n        view.IsolateElementsTemporary(List[ElementId](problem_ids))\r\n    except:\r\n        pass\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = \"Created view + isolated {} problem elements\".format(count)",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "c6201253c25a41d2924eb63332d9aa43",
