{
  "Uuid": "a1e78b06-3961-42ce-9926-e1f3bf03fbf2",
  "IsCustomNode": false,
  "Description": "",
  "Name": "Dynamo all in one script",
  "ElementResolver": {
    "ResolutionMap": {}
  },
  "Inputs": [],
  "Outputs": [],
  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference(\"RevitAPI\")\r\nclr.AddReference(\"RevitServices\")\r\n\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.DB.Plumbing import PipingSystem\r\nfrom RevitServices.Persistence import DocumentManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ndata = []\r\n\r\n# 🔧 Safe ElementId\r\ndef eid(elem_id):\r\n    try:\r\n        return str(elem_id.Value)\r\n    except:\r\n        return str(elem_id.IntegerValue)\r\n\r\n# 🔹 Hitta vatten-system\r\nvalid_ids = set()\r\n\r\nsystems = FilteredElementCollector(doc).OfClass(PipingSystem).ToElements()\r\n\r\nfor sys in systems:\r\n    try:\r\n        name = sys.Name.lower()\r\n\r\n        if any(k in name for k in [\"water\", \"cold\", \"hot\", \"cw\", \"hw\", \"sprink\", \"fire\"]):\r\n            try:\r\n                for e in sys.PipingNetwork:\r\n                    valid_ids.add(eid(e.Id))\r\n            except:\r\n                pass\r\n    except:\r\n        pass\r\n\r\n\r\n# 🔹 Pipes\r\npipes = FilteredElementCollector(doc)\\\r\n    .OfCategory(BuiltInCategory.OST_PipeCurves)\\\r\n    .WhereElementIsNotElementType()\\\r\n    .ToElements()\r\n\r\n\r\ndef get_connectors(elem):\r\n    try:\r\n        return elem.ConnectorManager\r\n    except:\r\n        return None\r\n\r\n\r\nfor p in pipes:\r\n\r\n    pid = eid(p.Id)\r\n\r\n    if pid not in valid_ids:\r\n        continue\r\n\r\n    mgr = get_connectors(p)\r\n\r\n    conn_count = 0\r\n    connected_ids = []\r\n\r\n    if mgr:\r\n        try:\r\n            for c in mgr.Connectors:\r\n                conn_count += 1\r\n\r\n                if c.IsConnected:\r\n                    for ref in c.AllRefs:\r\n                        owner = ref.Owner\r\n                        if owner and owner.Id != p.Id:\r\n                            connected_ids.append(eid(owner.Id))\r\n        except:\r\n            pass\r\n\r\n    # 🔥 Output som LISTA av dicts (inte dict med int keys)\r\n    data.append({\r\n        \"id\": pid,\r\n        \"connectors\": int(conn_count),\r\n        \"connected_to\": connected_ids\r\n    })\r\n\r\nOUT = data",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "10b16069077444bbbf8b113fdf7c4fc2",
      "NodeType": "PythonScriptNode",
      "Inputs": [
