    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "data = IN[0]\r\n\r\norphans = []\r\ndead_ends = []\r\nisolated = []\r\n\r\nfor e in data:\r\n    try:\r\n        eid = e[\"id\"]\r\n        conn = e[\"connectors\"]\r\n        connected = len(e[\"connected_to\"])\r\n\r\n        # 🔴 Hard orphan (har connectors men ingen connection)\r\n        if conn > 0 and connected == 0:\r\n            orphans.append(eid)\r\n\r\n        # 🟡 Dead-end (ska normalt vara genomgående rör)\r\n        elif conn >= 2 and connected == 1:\r\n            dead_ends.append(eid)\r\n\r\n        # 🔵 Isolated (inga connectors alls)\r\n        elif conn == 0:\r\n            isolated.append(eid)\r\n\r\n    except:\r\n        pass\r\n\r\nOUT = {\r\n    \"orphans\": orphans,\r\n    \"dead_ends\": dead_ends,\r\n    \"isolated\": isolated\r\n}",
      "Engine": "CPython3",
      "VariableInputPorts": true,
      "Id": "07e0a38ca734424c9f5441bfdefa92ce",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "6bd41aad61e24b228a80e0172909ffa0",
          "Name": "IN[0]",
          "Description": "Input #0",
